[Unit]
Description=Meek security agent - continuous monitoring
After=network.target

[Service]
Type=simple
User=root
ExecStart=/usr/bin/python3 /srv/ai/meek/meek.py watch --quiet
Restart=on-failure
RestartSec=30
ProtectSystem=full
PrivateTmp=yes
NoNewPrivileges=yes

[Install]
WantedBy=multi-user.target
